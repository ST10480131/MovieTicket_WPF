<Window x:Class="MovieTicket_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MovieTicket_WPF"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="MovieTickets" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <StackPanel Grid.Row="1" Margin="0,10">
            <TextBlock Text="Customer Name"/>
            <TextBox x:Name="txtName" Height="30"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,10">
            <TextBlock Text="Select Movie"/>
            <ComboBox x:Name="cmbMovies" Height="30">
                <ComboBoxItem Content="King" Tag="80"/>
                <ComboBoxItem Content="Black Panther" Tag="80"/>
                <ComboBoxItem Content="Avatar" Tag="50"/>
                <ComboBoxItem Content="The Bride!" Tag="85"/>
                <ComboBoxItem Content="Mercy" Tag="70"/>
                <ComboBoxItem Content="Send Help" Tag="75"/>
                <ComboBoxItem Content="Cherry" Tag="85"/>
            </ComboBox>


        </StackPanel>
        <StackPanel Grid.Row="3" Margin="0,10">
            <TextBlock Text="TicketType"/>
            <ComboBox x:Name="ticketType" Height="30">
                <ComboBoxItem Content="starndard Ticket" Tag="0"/>
                <ComboBoxItem Content="VIP" Tag="50"/>

            </ComboBox>

        </StackPanel>
        <StackPanel Grid.Row="4" Margin="0,10">
        <TextBlock Text="number of tickets"/>
        <TextBox x:Name="txtQuantity" Height="30"/>
        </StackPanel>
        <StackPanel Grid.Row="5" Margin="0,10">
            <Button Content="Calculate Ticket"
                    Height="35"
                    Click="CalculateTicket_Click"/>

            <TextBlock x:Name="txtResult"
                       Margin="0,20,0,0"
                       FontSize="16"
                       TextWrapping="Wrap"/>
            </StackPanel>
    </Grid>
</Window>
